.page {
  padding: 30rpx 28rpx 60rpx;
}

.header {
  padding: 16rpx 0 24rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 400;
  color: #5c544a;
  letter-spacing: 4rpx;
}

.hint {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.empty {
  text-align: center;
  color: #aaa;
  padding: 120rpx 40rpx;
  font-size: 26rpx;
  white-space: pre-line;
}

.trip-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.trip-card {
  display: flex;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.trip-cover {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  background: #f0eae0;
}

.trip-cover-empty {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  background: #f0eae0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  color: #c8b8a0;
}

.trip-body {
  flex: 1;
  padding: 24rpx 28rpx;
  min-width: 0;
}

.trip-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #2c2c2c;
  margin-bottom: 8rpx;
}

.trip-meta {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.trip-emojis {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  align-items: center;
}

.trip-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.trip-more {
  font-size: 22rpx;
  color: #aaa;
  margin-left: 6rpx;
}
